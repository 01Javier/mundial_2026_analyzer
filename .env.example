# ============================================================
# COPIA ESTE ARCHIVO COMO .env
# ============================================================

# API-Football / API-Sports
# Documentación: https://www.api-football.com/documentation-v3
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# football-data.org
# Documentación: https://www.football-data.org/documentation/quickstart
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION=WC
FOOTBALL_DATA_SEASON=2026

# Configuración general
USE_MOCK_DATA=true
GUATEMALA_TIMEZONE=America/Guatemala
USE_DIXON_COLES=true
DIXON_COLES_RHO=0.0
USE_MONTE_CARLO=true
MONTE_CARLO_SIMS=20000
API_PROVIDER_PRIORITY=api_football,football_data,csv,mock
ALLOW_API_ON_PAGE_LOAD=false
MAX_API_REQUESTS_PER_RUN=20
TEAM_FORM_CACHE_HOURS=72
AUTO_FIT_DIXON_COLES=true
DISABLE_DC_IF_DRAW_BIAS_HIGH=true
USE_DRAW_BIAS_CORRECTION=true
IGNORE_MOCK_RESULTS_FOR_CALIBRATION=true
